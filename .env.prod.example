# Copy this to .env.prod and fill in real values — never commit .env.prod

# ── Azure PostgreSQL ──────────────────────────────────────────────────────────
# Use the priovexapp user created by scripts/1-azure-db-setup.sh
# pgbouncer=true is NOT needed — Azure PostgreSQL uses direct connections
DATABASE_URL=postgresql://priovexapp:PASSWORD@priovex-db.postgres.database.azure.com:5432/priovex?sslmode=require
DATABASE_DIRECT_URL=postgresql://priovexapp:PASSWORD@priovex-db.postgres.database.azure.com:5432/priovex?sslmode=require

# ── Azure Cache for Redis (TLS port 6380, rediss:// scheme) ──────────────────
REDIS_URL=rediss://:ACCESS_KEY@priovex-redis.redis.cache.windows.net:6380

# ── Azure Blob Storage ────────────────────────────────────────────────────────
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=priovexstorage;AccountKey=KEY==;EndpointSuffix=core.windows.net
AZURE_STORAGE_CONTAINER=priovex-reports

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://priovex-app.centralindia.cloudapp.azure.com

# ── Clerk ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...
CLERK_SECRET_KEY=sk_live_...
CLERK_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_AGENCY_MONTHLY=price_...
STRIPE_PRICE_ENTERPRISE_MONTHLY=price_...

# ── AI Providers ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_GEMINI_API_KEY=AIza...
DEFAULT_AI_PROVIDER=claude

# ── Google BigQuery ───────────────────────────────────────────────────────────
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# ── GlitchTip (Sentry-compatible — same SDK, different DSN host) ──────────────
NEXT_PUBLIC_SENTRY_DSN=https://KEY@errors.priovex.idpd.app/1
SENTRY_DSN=https://KEY@errors.priovex.idpd.app/1
SENTRY_ORG=priovex
SENTRY_PROJECT=priovex-ai

# ── Azure Communication Services (email) ─────────────────────────────────────
AZURE_COMMUNICATION_CONNECTION_STRING=endpoint=https://priovex-email.communication.azure.com/;accesskey=KEY==
EMAIL_FROM=onboarding@resend.dev
EMAIL_SUPPORT=support@priovex.ai

# ── Workers ───────────────────────────────────────────────────────────────────
WORKER_CONCURRENCY=3
MAX_SEARCH_DURATION_MS=3600000
SEARCH_TIMEOUT_MS=2700000

# /opt/priovex/.env  — docker compose variable substitution file on the Azure VM
# This is NOT the app secrets file (.env.prod handles those).
# Docker Compose reads this automatically for ${VAR} substitution in docker-compose.prod.yml.
#
# Copy to /opt/priovex/.env on the VM and fill in real values.

# Azure Container Registry — your ACR login server URL
ACR_LOGIN_SERVER=priovex.azurecr.io

# Pinned by CI to the deployed commit SHA; set to 'latest' for manual runs
IMAGE_TAG=latest

// PrioVex.AI — Prisma Schema v2
// PostgreSQL with pgvector extension

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
  binaryTargets   = ["native", "linux-musl-openssl-3.0.x"]
  skipValidation  = true
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DATABASE_DIRECT_URL")
  extensions = [pgvector(map: "vector", schema: "extensions"), pg_trgm(map: "pg_trgm", schema: "extensions")]
}

// =============================================================================
// USERS & ORGANIZATIONS
// =============================================================================

model User {
  id                     String   @id @default(cuid())
  clerkId                String   @unique
  email                  String   @unique
  name                   String
  avatarUrl              String?
  role                   UserRole @default(USER)
  stripeCustomerId       String?  @unique
  subscriptionId         String?  @unique
  subscriptionTier       PlanTier @default(FREE)
  subscriptionStatus     SubStatus @default(ACTIVE)
  subscriptionPeriodEnd  DateTime?
  searchesUsedThisMonth  Int      @default(0)
  searchQuotaLimit       Int      @default(1)
  lastQuotaResetAt       DateTime @default(now())
  organizationId         String?
  organization           Organization? @relation(fields: [organizationId], references: [id])
  searches               Search[]
  reports                Report[]
  uploadedFiles          UploadedFile[]
  auditLogs              AuditLog[]
  apiKeys                ApiKey[]
  notifications          Notification[]
  sentInvites            OrganizationInvite[] @relation("SentInvites")
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@index([clerkId])
  @@index([email])
  @@index([organizationId])
  @@map("users")
}

model Organization {
  id                    String    @id @default(cuid())
  clerkOrgId            String?   @unique
  name                  String
  slug                  String    @unique
  logoUrl               String?
  ownerId               String?
  stripeCustomerId      String?   @unique
  subscriptionId        String?   @unique
  subscriptionTier      PlanTier  @default(PRO)
  subscriptionStatus    SubStatus @default(ACTIVE)
  subscriptionPeriodEnd DateTime?
  searchQuotaLimit      Int       @default(50)
  searchesUsedThisMonth Int       @default(0)
  lastQuotaResetAt      DateTime  @default(now())
  members               User[]
  searches              Search[]
  invites               OrganizationInvite[]
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("organizations")
}

model OrganizationInvite {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  email          String
  token          String       @unique @default(cuid())
  invitedById    String
  invitedBy      User         @relation("SentInvites", fields: [invitedById], references: [id])
  accepted       Boolean      @default(false)
  acceptedAt     DateTime?
  expiresAt      DateTime
  createdAt      DateTime     @default(now())

  @@index([organizationId])
  @@index([token])
  @@index([email])
  @@map("organization_invites")
}

// =============================================================================
// SEARCHES
// =============================================================================

model Search {
  id                String       @id @default(cuid())
  userId            String
  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId    String?
  organization      Organization? @relation(fields: [organizationId], references: [id])

  // Input
  title             String
  description       String       @db.Text
  technicalField    String
  problemSolved     String       @db.Text
  keyInnovations    String[]
  claimsDraft       String?      @db.Text
  jurisdictions     String[]
  depth             SearchDepth  @default(STANDARD)
  searchType        SearchType   @default(PATENTABILITY)
  aiProvider        AIProviderType @default(CLAUDE)
  reportStyle       ReportStyle  @default(COMPREHENSIVE)

  // Status
  status            SearchStatus @default(QUEUED)
  currentStep       Int          @default(0)
  totalSteps        Int          @default(14)
  progressPercent   Int          @default(0)
  patentsFound      Int          @default(0)
  patentsAnalyzed   Int          @default(0)
  nplFound          Int          @default(0)
  errorMessage      String?

  // Timing
  queuedAt          DateTime     @default(now())
  startedAt         DateTime?
  completedAt       DateTime?
  durationSeconds   Int?

  // Queue
  bullJobId         String?      @unique
  retryCount        Int          @default(0)
  cancelRequested   Boolean      @default(false)

  // Confidential mode
  confidentialMode  Boolean      @default(false)
  encryptionKeyId   String?

  // Relations
  report            Report?
  progressLogs      ProgressLog[]
  uploadedFiles     SearchFile[]
  savedPatents      SavedPatent[]

  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@index([userId])
  @@index([organizationId])
  @@index([status])
  @@index([searchType])
  @@index([createdAt])
  @@map("searches")
}

model ProgressLog {
  id        String   @id @default(cuid())
  searchId  String
  search    Search   @relation(fields: [searchId], references: [id], onDelete: Cascade)
  level     LogLevel @default(INFO)
  message   String
  metadata  Json?
  timestamp DateTime @default(now())

  @@index([searchId])
  @@index([timestamp])
  @@map("progress_logs")
}

// =============================================================================
// REPORTS (v2 — extended)
// =============================================================================

model Report {
  id          String @id @default(cuid())
  searchId    String @unique
  search      Search @relation(fields: [searchId], references: [id], onDelete: Cascade)
  userId      String
  user        User   @relation(fields: [userId], references: [id])

  inventionTitle       String
  reportStyle          ReportStyle
  searchType           SearchType @default(PATENTABILITY)

  // Assessment
  patentabilityScore   Int?
  noveltyRating        String?
  obviousnessRating    String?
  overallVerdict       String?
  executiveSummary     String?    @db.Text
  patentabilityData    Json?
  claimStrategyData    Json?

  // v2 — Core intelligence layers
  novelElementsData    Json?      // NovelElement[] — claim-like decomposition
  coverageMatrixData   Json?      // CoverageMatrix — element × reference grid
  idsEntriesData       Json?      // IDSEntry[] — USPTO-ready IDS table
  examinerSimulationData Json?    // ExaminerPrediction
  gapClaimDraftData    Json?      // GapGroundedClaimDraft

  // v2 — NPL intelligence
  nplReferencesData    Json?      // NPLReference[]
  nplStatisticsData    Json?      // NPL search stats

  // Data
  conceptData          Json?
  keywordData          Json?
  topPriorArtData      Json?
  allPatentsData       Json?
  timelineData         Json?
  assigneeData         Json?
  statisticsData       Json?
  idsReferences        String[]

  // v2 — Dual report content
  markdownContent      String?    @db.Text   // Internal technical report
  htmlContent          String?    @db.Text   // Internal HTML report
  clientReportContent  String?    @db.Text   // Clean client-facing supplementary report
  clientReportHtml     String?    @db.Text   // Client report in HTML

  // Storage URLs (Supabase)
  pdfStorageUrl        String?
  clientPdfStorageUrl  String?
  jsonStorageUrl       String?
  markdownStorageUrl   String?
  clientReportStorageUrl String?

  // AI metadata
  aiProvider           AIProviderType
  aiModel              String
  aiTokensUsed         Int        @default(0)
  aiCostUsd            Float      @default(0)

  // BigQuery metadata
  bqBytesProcessed     BigInt     @default(0)
  bqCostUsd            Float      @default(0)

  // Sharing
  shareToken           String?    @unique
  shareExpiresAt       DateTime?
  shareViewCount       Int        @default(0)

  // FTO (Freedom-to-Operate) lite
  ftoRiskData          Json?      // FTORiskAnalysis

  // Disclaimer applied
  disclaimerVersion    String?    @default("v1")

  generatedAt          DateTime   @default(now())
  updatedAt            DateTime   @updatedAt

  @@index([userId])
  @@index([searchId])
  @@index([shareToken])
  @@map("reports")
}

// =============================================================================
// PATENTS & SAVED PATENTS
// =============================================================================

model PatentCache {
  id                String    @id @default(cuid())
  publicationNumber String    @unique
  title             String?
  abstract          String?   @db.Text
  claims            String?   @db.Text
  fullClaims        Json?     // Structured claims from PatentsView
  description       String?   @db.Text
  filingDate        String?
  grantDate         String?
  assignees         String[]
  inventors         String[]
  cpcCodes          String[]
  ipcCodes          String[]
  countryCode       String?
  rawData           Json
  claimsSource      String?   // "patentsview" | "bigquery" | "uspto"
  cachedAt          DateTime  @default(now())
  expiresAt         DateTime

  @@index([publicationNumber])
  @@index([cachedAt])
  @@map("patent_cache")
}

model SavedPatent {
  id                String   @id @default(cuid())
  searchId          String
  search            Search   @relation(fields: [searchId], references: [id], onDelete: Cascade)
  publicationNumber String
  title             String
  relevanceScore    Int
  similarityScore   Int
  rank              Int
  notes             String?
  createdAt         DateTime @default(now())

  @@unique([searchId, publicationNumber])
  @@index([searchId])
  @@map("saved_patents")
}

// =============================================================================
// NPL REFERENCE CACHE
// =============================================================================

model NplCache {
  id              String   @id @default(cuid())
  sourceId        String   @unique  // arxiv:2301.XXXXX | ss:paper_id | doi:10.xxx
  source          String            // "arxiv" | "semantic_scholar" | "ieee" | "uspto_efts"
  title           String
  authors         String[]
  abstract        String?  @db.Text
  publicationDate String?
  url             String?
  doi             String?
  categories      String[]
  citationCount   Int?
  rawData         Json
  cachedAt        DateTime @default(now())
  expiresAt       DateTime

  @@index([sourceId])
  @@index([source])
  @@index([cachedAt])
  @@map("npl_cache")
}

// =============================================================================
// FILES
// =============================================================================

model UploadedFile {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  filename    String
  mimeType    String
  sizeBytes   Int
  storageKey  String   @unique
  storageUrl  String
  scanned     Boolean  @default(false)
  scanPassed  Boolean  @default(false)
  createdAt   DateTime @default(now())
  searches    SearchFile[]

  @@index([userId])
  @@map("uploaded_files")
}

model SearchFile {
  searchId String
  fileId   String
  search   Search       @relation(fields: [searchId], references: [id], onDelete: Cascade)
  file     UploadedFile @relation(fields: [fileId], references: [id])

  @@id([searchId, fileId])
  @@map("search_files")
}

// =============================================================================
// BILLING
// =============================================================================

model StripeEvent {
  id          String   @id
  type        String
  payload     Json
  processed   Boolean  @default(false)
  processedAt DateTime?
  error       String?
  createdAt   DateTime @default(now())

  @@index([type])
  @@index([processed])
  @@map("stripe_events")
}

// =============================================================================
// API KEYS
// =============================================================================

model ApiKey {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  keyHash     String    @unique
  keyPrefix   String
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  revokedAt   DateTime?
  usageCount  Int       @default(0)
  createdAt   DateTime  @default(now())

  @@index([userId])
  @@index([keyHash])
  @@map("api_keys")
}

// =============================================================================
// AUDIT LOGS
// =============================================================================

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  resource  String
  resourceId String?
  metadata  Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

// =============================================================================
// NOTIFICATIONS
// =============================================================================

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  message   String
  readAt    DateTime?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([readAt])
  @@map("notifications")
}

// =============================================================================
// SYSTEM CONFIG (admin-managed key-value store)
// =============================================================================

model SystemConfig {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt

  @@map("system_configs")
}

// =============================================================================
// ADMIN ANALYTICS
// =============================================================================

model DailyStats {
  id                   String   @id @default(cuid())
  date                 DateTime @unique @db.Date
  newUsers             Int      @default(0)
  newSearches          Int      @default(0)
  completedSearches    Int      @default(0)
  failedSearches       Int      @default(0)
  totalAiTokens        Int      @default(0)
  totalAiCostUsd       Float    @default(0)
  totalBqCostUsd       Float    @default(0)
  revenueUsd           Float    @default(0)
  activeSubscriptions  Int      @default(0)
  totalNplSearches     Int      @default(0)

  @@map("daily_stats")
}

// =============================================================================
// ENUMS
// =============================================================================

enum UserRole {
  USER
  ADMIN
  ENTERPRISE
}

enum PlanTier {
  FREE
  PRO
  AGENCY
  ENTERPRISE
}

enum SubStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELLED
  UNPAID
}

enum SearchType {
  PATENTABILITY
  INVALIDITY
  FTO
  NOVELTY
  EXAMINER_STYLE
}

enum SearchStatus {
  QUEUED
  EXTRACTING
  NOVEL_ELEMENTS
  KEYWORD_STRATEGY
  BROAD_SEARCH
  CPC_IDENTIFICATION
  DEEP_CPC_SEARCH
  NPL_SEARCH
  CLAIMS_RETRIEVAL
  TIMELINE_ANALYSIS
  AI_SCORING
  COVERAGE_ANALYSIS
  IDS_GENERATION
  EXAMINER_SIMULATION
  GENERATING_REPORT
  COMPLETED
  FAILED
  CANCELLED
}

enum SearchDepth {
  QUICK
  STANDARD
  THOROUGH
}

enum AIProviderType {
  CLAUDE
  OPENAI
  GEMINI
}

enum ReportStyle {
  LEGAL
  TECHNICAL
  INVESTOR
  CONCISE
  COMPREHENSIVE
}

enum LogLevel {
  INFO
  WARN
  ERROR
  SUCCESS
}

# Copy this to .env.glitchtip and fill in real values — never commit .env.glitchtip

# Generate with: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=REPLACE_WITH_50_CHAR_RANDOM_STRING

# GlitchTip gets its own database on the same Azure PostgreSQL server
DATABASE_URL=postgresql://priovexapp:PASSWORD@priovex-db.postgres.database.azure.com:5432/glitchtip?sslmode=require

# Shares the same Azure Cache for Redis as the app (separate key namespace)
REDIS_URL=rediss://:ACCESS_KEY@priovex-redis.redis.cache.windows.net:6380

GLITCHTIP_DOMAIN=https://errors.priovex.idpd.app
DEFAULT_FROM_EMAIL=errors@priovex.ai

# SMTP for GlitchTip alert emails — use Azure Communication Services SMTP relay
# Format: smtp://USER:PASS@HOST:PORT
EMAIL_URL=smtp://priovex-email.smtp.azurecomm.net:587

# Initial superuser — change password immediately after first login
DJANGO_SUPERUSER_EMAIL=admin@priovex.ai
DJANGO_SUPERUSER_PASSWORD=CHANGE_ME_ON_FIRST_LOGIN

ENABLE_OPEN_USER_REGISTRATION=False
